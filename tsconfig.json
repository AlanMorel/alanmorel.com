{
    "compilerOptions": {
        "target": "ESNext",
        "types": ["node"],
        "skipLibCheck": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "incremental": true,
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": true,
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["./*"]
        },
        "lib": ["dom", "esnext"]
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules"]
}
